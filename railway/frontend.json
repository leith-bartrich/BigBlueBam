{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/frontend/Dockerfile",
    "watchPatterns": [
      "apps/frontend/**",
      "packages/shared/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "package.json",
      "tsconfig.base.json",
      "apps/frontend/Dockerfile",
      "infra/nginx/**"
    ],
    "buildArgs": {
      "NGINX_PROFILE": "railway"
    }
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/",
    "healthcheckTimeout": 100
  }
}
