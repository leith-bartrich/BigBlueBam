# ─── Required ────────────────────────────────────────────────
POSTGRES_USER=bigbluebam
POSTGRES_PASSWORD=change-me-in-production
REDIS_PASSWORD=change-me-in-production
MINIO_ROOT_USER=change-me-in-production
MINIO_ROOT_PASSWORD=change-me-in-production
SESSION_SECRET=generate-a-random-string-at-least-32-chars
# HB-7: Shared secret between helpdesk-api and the BBB /internal/helpdesk/*
# surface. Must be 32+ chars. Generate with e.g. `openssl rand -hex 32`.
INTERNAL_HELPDESK_SECRET=changeme-generate-a-32-char-random-string-for-production

# Wave 0.2: shared secret for cross-service internal POSTs, including the
# mcp-server /tools/call route and the Bolt ingest X-Internal-Secret check.
# Must be 32+ chars. Generate with e.g. `openssl rand -hex 32`.
INTERNAL_SERVICE_SECRET=changeme-generate-a-32-char-random-string-for-production
# Wave 0.2: bearer token the mcp-server /tools/call route uses when it
# proxies through ApiClient. Create with:
#   docker compose exec api node dist/cli.js create-service-account \
#     --name mcp-internal --org-slug <your-org-slug>
# Paste the printed bbam_svc_ token here.
MCP_INTERNAL_API_TOKEN=

# ─── Optional Overrides ─────────────────────────────────────
# API_PORT=4000
# MCP_PORT=3001
# HTTP_PORT=80
# HTTPS_PORT=443
# LOG_LEVEL=info
# WORKER_CONCURRENCY=5
# CORS_ORIGIN=https://your-domain.com
# VERSION=1.0.0

# ─── OAuth Providers (optional) ──────────────────────────────
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=

# ─── LiveKit (for Banter voice/video) ────────────────────────
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret

# ─── Email / SMTP (optional — logs only if not set) ─────────
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxx
# SMTP_FROM=noreply@bigbluebam.io

# ─── Documentation Capture (optional) ───────────────────────
# Credentials for the Playwright screenshot capture pipeline.
# Defaults target the seeded dev stack admin user.
DOCS_CAPTURE_USER=admin@example.com
DOCS_CAPTURE_PASSWORD=BigBlueBam-2026-dev-pw
