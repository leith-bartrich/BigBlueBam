{
  "name": "bigbluebam",
  "private": true,
  "version": "1.0.0",
  "description": "Web-based multi-user Kanban project planning tool",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "pnpm --filter @bigbluebam/e2e test",
    "test:e2e:b3": "pnpm --filter @bigbluebam/e2e test:b3",
    "test:e2e:ui": "pnpm --filter @bigbluebam/e2e test:ui",
    "test:e2e:report": "pnpm --filter @bigbluebam/e2e report",
    "clean": "turbo run clean",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:build": "docker compose build",
    "db:migrate": "docker compose run --rm migrate",
    "db:check": "node scripts/db-check.mjs",
    "seed": "node scripts/seed-all.mjs",
    "check:bolt-catalog": "node scripts/check-bolt-catalog.mjs",
    "lint:migrations": "node scripts/lint-migrations.mjs",
    "db:generate": "pnpm --filter @bigbluebam/api db:generate",
    "db:push": "pnpm --filter @bigbluebam/api db:push",
    "docs:screenshots": "node scripts/docs/capture.mjs",
    "docs:extract": "node scripts/docs/extract.mjs",
    "docs:compose": "node scripts/docs/compose.mjs",
    "docs:publish": "node scripts/docs/publish.mjs",
    "docs:generate": "node scripts/docs/generate.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
