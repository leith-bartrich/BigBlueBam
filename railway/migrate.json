{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/api/Dockerfile",
    "watchPatterns": [
      "apps/api/**",
      "packages/shared/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "package.json",
      "tsconfig.base.json",
      "apps/api/Dockerfile",
      "infra/postgres/migrations/**"
    ]
  },
  "deploy": {
    "startCommand": "node dist/migrate.js",
    "restartPolicyType": "NEVER"
  }
}
