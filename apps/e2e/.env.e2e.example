# E2E Test Configuration
# Copy to .env.e2e and fill in values

# Base URL of the running stack (nginx on port 80)
E2E_BASE_URL=http://localhost

# Test admin user credentials (created by global setup if they don't exist)
E2E_ADMIN_EMAIL=e2e-admin@bigbluebam.test
E2E_ADMIN_PASSWORD=E2eTestP@ss123!

# Test member user credentials
E2E_MEMBER_EMAIL=e2e-member@bigbluebam.test
E2E_MEMBER_PASSWORD=E2eTestP@ss123!

# Test org name
E2E_ORG_NAME=E2E Test Organization
