# ─── Required ────────────────────────────────────────────────
POSTGRES_USER=bigbluebam
POSTGRES_PASSWORD=change-me-in-production
REDIS_PASSWORD=change-me-in-production
MINIO_ROOT_USER=change-me-in-production
MINIO_ROOT_PASSWORD=change-me-in-production
SESSION_SECRET=generate-a-random-string-at-least-32-chars
# HB-7: Shared secret between helpdesk-api and the BBB /internal/helpdesk/*
# surface. Must be 32+ chars. Generate with e.g. `openssl rand -hex 32`.
INTERNAL_HELPDESK_SECRET=changeme-generate-a-32-char-random-string-for-production

# Wave 0.2: shared secret for cross-service internal POSTs, including the
# mcp-server /tools/call route and the Bolt ingest X-Internal-Secret check.
# Must be 32+ chars. Generate with e.g. `openssl rand -hex 32`.
INTERNAL_SERVICE_SECRET=changeme-generate-a-32-char-random-string-for-production
# Wave 0.2: bearer token the mcp-server /tools/call route uses when it
# proxies through ApiClient. Create with:
#   docker compose exec api node dist/cli.js create-service-account \
#     --name mcp-internal --org-slug <your-org-slug>
# Paste the printed bbam_svc_ token here.
MCP_INTERNAL_API_TOKEN=

# ─── Optional Overrides ─────────────────────────────────────
# API_PORT=4000
# MCP_PORT=3001
# Host-port bindings. The deploy script (scripts/deploy/main.mjs) walks you
# through customizing these if any conflict with services already running on
# the host — common on NAS systems where 80/443 are taken by the device
# admin UI and 7880/7881 may collide with existing media services. Set them
# by hand here as an alternative. Container-internal ports stay fixed; only
# the host-side number changes.
# HTTP_PORT=80
# HTTPS_PORT=443
# LIVEKIT_RTC_PORT=7880
# LIVEKIT_TCP_PORT=7881

# ─── Local TLS / SSL ────────────────────────────────────────
# Provisioned by the deploy script (scripts/deploy/main.mjs) when you opt
# into TLS. nginx detects ./certs/local.crt + ./certs/local.key at boot;
# if absent, the stack runs HTTP-only regardless of TLS_HTTP_MODE.
# See docs/local-ssl-notes.md for the full picture.
#   none        — explicit kill switch (no TLS even with certs present)
#   redirect    — port 80 issues 301 to https (default; recommended)
#   both        — port 80 keeps serving content (LAN/internal-tooling case)
#   https-only  — port 80 returns 444 (drops the connection)
# TLS_HTTP_MODE=none
# Externally-visible HTTPS port (used in 301 redirect targets when the
# operator remapped HTTPS_PORT). Defaults to HTTPS_PORT when unset.
# EXT_HTTPS_PORT=443
# Hint to the entrypoint about how aggressive HSTS should be:
#   self-signed | mkcert | byo  → max-age=300 (avoid poisoning Chrome's HSTS)
#   letsencrypt                 → max-age=31536000; includeSubDomains
# TLS_CERT_SOURCE=self-signed

# ─── Cookie hardening ───────────────────────────────────────
# Set to true to mark every session cookie Secure (HTTPS-only). The deploy
# script writes this automatically when you opt into TLS. Required for
# secure-by-default cookies in any TLS deployment; harmless on Railway
# (which terminates TLS upstream and forwards X-Forwarded-Proto).
# COOKIE_SECURE=false

# ─── Let's Encrypt (only when TLS_CERT_SOURCE=letsencrypt) ──
# LETSENCRYPT_DOMAIN=
# LETSENCRYPT_EMAIL=
# LETSENCRYPT_AGREE_TOS=false
# LOG_LEVEL=info
# WORKER_CONCURRENCY=5
# CORS_ORIGIN=https://your-domain.com
# VERSION=1.0.0

# ─── OAuth Providers (optional) ──────────────────────────────
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=

# ─── LiveKit (for Banter voice/video) ────────────────────────
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret

# ─── Email / SMTP (optional — logs only if not set) ─────────
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxx
# SMTP_FROM=noreply@bigbluebam.io

# ─── Documentation Capture (optional) ───────────────────────
# Credentials for the Playwright screenshot capture pipeline.
# Defaults target the seeded dev stack admin user.
DOCS_CAPTURE_USER=admin@example.com
DOCS_CAPTURE_PASSWORD=BigBlueBam-2026-dev-pw
